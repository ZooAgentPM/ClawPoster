# ── 私有核心资产（不进公开仓库）──────────────────────────────
data/
*.pkl

# json 默认排除，但 demo 数据包例外
*.json
!data-demo/**/*.json

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
build/

# ── 运行时产物 ────────────────────────────────────────────────
renders/
screenshots/
/tmp/
*.png
*.jpg
*.jpeg
*.zip

# ── 环境变量 ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── 系统文件 ──────────────────────────────────────────────────
.DS_Store
*.log
nohup.out
